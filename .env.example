# CrisisOS Environment Variables
# Copy to .env and fill in your keys

GEMINI_API_KEY=
ORS_API_KEY=
SIMULATION_CITY=Delhi
ENABLE_BASELINE=true

# Disaster timing (tick numbers, 1 tick = 2 seconds)
DISASTER_TICK_EARTHQUAKE=15
DISASTER_TICK_ROAD_COLLAPSE=25
DISASTER_TICK_FIRE=35
DISASTER_TICK_HOSPITAL_OVERLOAD=50

# Conflict scenario timing
CONFLICT_TICK_ROAD_SACRIFICE=35
CONFLICT_TICK_RESOURCE_EXHAUSTION=65

# Server
HOST=0.0.0.0
PORT=8000
